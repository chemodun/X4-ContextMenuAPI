<?xml version="1.0" encoding="utf-8"?>
<mdscript name="Context_Menu_API_Demo"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../libraries/md.xsd">

    <!--
    Context Menu API Demo — MD-level consumer demo.

    Demonstrates entry injection in all supported modes:
      info_context, personnel (MapMenu / PlayerInfoMenu),
      inventory and transactionlog (PlayerInfoMenu).

    The header of the custom sub-menu shows context-specific info:
      info_context  — NPC name/role (entity or person), or weapon / equipment /
                      software / inventory ware macro string
      personnel     — NPC name + role (resolved by the API: $name, $rolename)
      inventory     — ware display name ($name)
      transactionlog — entry ID ($entryid)

    MENU TREE (appended to every supported vanilla mode):
      [vanilla mode]
        ─── (separator)
        [MD] Demo: Multi-Level Menu >   ← submenu → cmt_md_main
        ─── (separator)
        [MD] Action 1                   → On_CMAD_Action_1  (show_notification)
        [MD] Action 2                   → On_CMAD_Action_2  (show_notification)

      [cmt_md_main]           (custom mode, blank frame)
        <context header>       (see above for logic)
        < Back                 (auto-generated by API)
        [MD] Item A  >         → cmt_md_sub_a
        [MD] Item B  >         → cmt_md_sub_b

      [cmt_md_sub_a]
        [MD] Sub-Menu A  (header)
        < Back
        [MD] A - Action 1   → On_CMAD_SubA_Action_1  (show_notification)
        [MD] A - Action 2   → On_CMAD_SubA_Action_2  (show_notification)

      [cmt_md_sub_b]
        [MD] Sub-Menu B  (header)
        < Back
        [MD] B - Action 1   → On_CMAD_SubB_Action_1  (show_notification)
        [MD] B - Action 2   → On_CMAD_SubB_Action_2  (show_notification)

    Note: subMenu entries do not include ">" in $text — the API appends it automatically.
    -->

    <cues>

        <!-- ================================================================== -->
        <!--  Add entries each time a context frame is about to open              -->
        <!-- ================================================================== -->

        <cue name="On_CMAD_Get_Actions" instantiate="true">
            <conditions>
                <event_cue_signalled cue="md.Context_Menu_API.Get_Actions" />
            </conditions>
            <actions>
                <debug_text text="'ContextMenuAPI Demo: Get_Actions, mode = %1, all: %s'.[event.param.$mode, event.param]" />

                <!-- ── All supported first-level vanilla modes ── -->
                <do_if value="event.param.$mode == 'info_context' or event.param.$mode == 'personnel' or event.param.$mode == 'inventory' or event.param.$mode == 'transactionlog'">
                    <debug_text text="'ContextMenuAPI Demo: Adding entries to mode %1'.[event.param.$mode]" />
                    <signal_cue_instantly cue="md.Context_Menu_API.Add_Action"
                        param="table[$type = 'separator']" />
                    <signal_cue_instantly cue="md.Context_Menu_API.Add_Action"
                        param="table[
                                $type = 'subMenu',
                                $text = '[MD] Demo: Multi-Level Menu',
                                $id   = 'cmt_md_main',
                            ]" />
                    <signal_cue_instantly cue="md.Context_Menu_API.Add_Action"
                        param="table[$type = 'separator']" />
                    <signal_cue_instantly cue="md.Context_Menu_API.Add_Action"
                        param="table[
                            $type      = 'menuItem',
                            $text      = '[MD] Action 1',
                            $id        = 'cmad_action_1',
                            $callback  = On_CMAD_Action_1,
                            $textColor = 'text_positive',
                            $icon      = 'order_follow',
                            $keepOpen  = true,
                        ]" />
                    <signal_cue_instantly cue="md.Context_Menu_API.Add_Action"
                        param="table[
                            $type      = 'menuItem',
                            $text      = '[MD] Action 2',
                            $id        = 'cmad_action_2',
                            $callback  = On_CMAD_Action_2,
                            $textColor = 'text_negative',
                        ]" />
                </do_if>

                <!-- ── cmt_md_main: top-level custom menu ── -->
                <do_elseif value="event.param.$mode == 'cmt_md_main'">
                    <!-- Context header: label depends on root mode and data -->
                    <set_value name="$headerLabel" exact="'[MD] Demo: Multi-Level Menu'" />
                    <do_if value="event.param.$rootMode == 'info_context'">
                        <!-- entity: pilot / captain / manager -->
                        <do_if value="@event.param.$entity != null">
                            <set_value name="$headerLabel" exact="@event.param.$entity.knownname" />
                            <do_if value="@event.param.$component.isclass.ship_s">
                                <set_value name="$headerLabel" exact="$headerLabel + ' (Pilot)'" />
                            </do_if>
                            <do_elseif value="@event.param.$component.isclass.ship">
                                <set_value name="$headerLabel" exact="$headerLabel + ' (Captain)'" />
                            </do_elseif>
                            <do_else>
                                <set_value name="$headerLabel" exact="$headerLabel + ' (Manager)'" />
                            </do_else>
                        </do_if>
                        <!-- person: crew NPC -->
                        <do_elseif value="@event.param.$person != null">
                            <set_value name="$headerLabel"
                                exact="@event.param.$component.people.{event.param.$person}.name
                                     + ' ('
                                     + @event.param.$component.people.{event.param.$person}.role.name
                                     + ')'" />
                        </do_elseif>
                        <!-- loadout items -->
                        <do_elseif value="@event.param.$weaponmacro != null">
                            <set_value name="$headerLabel" exact="'Weapon: %1'.[@event.param.$weaponmacro]" />
                        </do_elseif>
                        <do_elseif value="@event.param.$equipmentmacro != null">
                            <set_value name="$headerLabel" exact="'Equipment: %1'.[@event.param.$equipmentmacro]" />
                        </do_elseif>
                        <do_elseif value="@event.param.$software != null">
                            <set_value name="$headerLabel" exact="'Software: %1'.[@event.param.$software]" />
                        </do_elseif>
                        <!-- pilot inventory item -->
                        <do_elseif value="@event.param.$inv_ware != null">
                            <set_value name="$headerLabel" exact="'Ware: %1'.[@event.param.$inv_ware]" />
                        </do_elseif>
                    </do_if>
                    <!-- personnel: $name and $rolename resolved by the API -->
                    <do_elseif value="event.param.$rootMode == 'personnel'">
                        <do_if value="@event.param.$name != null">
                            <set_value name="$headerLabel" exact="'%1 (%2)'.[event.param.$name, event.param.$rolename]" />
                        </do_if>
                    </do_elseif>
                    <!-- inventory: $name is the ware display name -->
                    <do_elseif value="event.param.$rootMode == 'inventory'">
                        <do_if value="@event.param.$name != null">
                            <set_value name="$headerLabel" exact="event.param.$name" />
                        </do_if>
                    </do_elseif>
                    <!-- transactionlog: show entry ID -->
                    <do_elseif value="event.param.$rootMode == 'transactionlog'">
                        <do_if value="@event.param.$entryid != null">
                            <set_value name="$headerLabel" exact="'Entry #%1'.[event.param.$entryid]" />
                        </do_if>
                    </do_elseif>
                    <signal_cue_instantly cue="md.Context_Menu_API.Add_Action"
                        param="table[$type = 'header', $text = $headerLabel]" />
                    <signal_cue_instantly cue="md.Context_Menu_API.Add_Action"
                        param="table[
                            $type = 'subMenu',
                            $text = '[MD] Item A',
                            $id   = 'cmt_md_sub_a',
                        ]" />
                    <signal_cue_instantly cue="md.Context_Menu_API.Add_Action"
                        param="table[
                            $type = 'subMenu',
                            $text = '[MD] Item B',
                            $id   = 'cmt_md_sub_b',
                        ]" />
                </do_elseif>

                <!-- ── cmt_md_sub_a: sub-menu A ── -->
                <do_elseif value="event.param.$mode == 'cmt_md_sub_a'">
                    <signal_cue_instantly cue="md.Context_Menu_API.Add_Action"
                        param="table[$type = 'header', $text = '[MD] Sub-Menu A']" />
                    <signal_cue_instantly cue="md.Context_Menu_API.Add_Action"
                        param="table[
                            $type     = 'menuItem',
                            $text     = '[MD] A - Action 1',
                            $id       = 'cmad_a_action_1',
                            $callback = On_CMAD_SubA_Action_1,
                        ]" />
                    <signal_cue_instantly cue="md.Context_Menu_API.Add_Action"
                        param="table[
                            $type     = 'menuItem',
                            $text     = '[MD] A - Action 2',
                            $id       = 'cmad_a_action_2',
                            $callback = On_CMAD_SubA_Action_2,
                        ]" />
                </do_elseif>

                <!-- ── cmt_md_sub_b: sub-menu B ── -->
                <do_elseif value="event.param.$mode == 'cmt_md_sub_b'">
                    <signal_cue_instantly cue="md.Context_Menu_API.Add_Action"
                        param="table[$type = 'header', $text = '[MD] Sub-Menu B']" />
                    <signal_cue_instantly cue="md.Context_Menu_API.Add_Action"
                        param="table[
                            $type     = 'menuItem',
                            $text     = '[MD] B - Action 1',
                            $id       = 'cmad_b_action_1',
                            $callback = On_CMAD_SubB_Action_1,
                        ]" />
                    <signal_cue_instantly cue="md.Context_Menu_API.Add_Action"
                        param="table[
                            $type     = 'menuItem',
                            $text     = '[MD] B - Action 2',
                            $id       = 'cmad_b_action_2',
                            $callback = On_CMAD_SubB_Action_2,
                        ]" />
                </do_elseif>

            </actions>
        </cue>


        <!-- ================================================================== -->
        <!--  First-level callbacks                                              -->
        <!-- ================================================================== -->

        <cue name="On_CMAD_Action_1" instantiate="true">
            <conditions>
                <event_cue_signalled />
            </conditions>
            <actions>
                <debug_text text="'ContextMenuAPI Demo: Action 1 triggered, id=%1'.[event.param.$id]" chance="100" filter="general" />
                <show_notification title="'[MD] Context Menu API Demo'" text="'Action triggered: %1'.[event.param.$id]" />
            </actions>
        </cue>

        <cue name="On_CMAD_Action_2" instantiate="true">
            <conditions>
                <event_cue_signalled />
            </conditions>
            <actions>
                <debug_text text="'ContextMenuAPI Demo: Action 2 triggered, id=%1'.[event.param.$id]" chance="100" filter="general" />
                <show_notification title="'[MD] Context Menu API Demo'" text="'Action triggered: %1'.[event.param.$id]" />
            </actions>
        </cue>

        <!-- ================================================================== -->
        <!--  Sub-menu A callbacks                                               -->
        <!-- ================================================================== -->

        <cue name="On_CMAD_SubA_Action_1" instantiate="true">
            <conditions>
                <event_cue_signalled />
            </conditions>
            <actions>
                <debug_text text="'ContextMenuAPI Demo: Sub-A Action 1 triggered, id=%1'.[event.param.$id]" chance="100" filter="general" />
                <show_notification title="'[MD] Context Menu API Demo'" text="'Sub-A action triggered: %1'.[event.param.$id]" />
            </actions>
        </cue>

        <cue name="On_CMAD_SubA_Action_2" instantiate="true">
            <conditions>
                <event_cue_signalled />
            </conditions>
            <actions>
                <debug_text text="'ContextMenuAPI Demo: Sub-A Action 2 triggered, id=%1'.[event.param.$id]" chance="100" filter="general" />
                <show_notification title="'[MD] Context Menu API Demo'" text="'Sub-A action triggered: %1'.[event.param.$id]" />
            </actions>
        </cue>

        <!-- ================================================================== -->
        <!--  Sub-menu B callbacks                                               -->
        <!-- ================================================================== -->

        <cue name="On_CMAD_SubB_Action_1" instantiate="true">
            <conditions>
                <event_cue_signalled />
            </conditions>
            <actions>
                <debug_text text="'ContextMenuAPI Demo: Sub-B Action 1 triggered, id=%1'.[event.param.$id]" chance="100" filter="general" />
                <show_notification title="'[MD] Context Menu API Demo'" text="'Sub-B action triggered: %1'.[event.param.$id]" />
            </actions>
        </cue>

        <cue name="On_CMAD_SubB_Action_2" instantiate="true">
            <conditions>
                <event_cue_signalled />
            </conditions>
            <actions>
                <debug_text text="'ContextMenuAPI Demo: Sub-B Action 2 triggered, id=%1'.[event.param.$id]" chance="100" filter="general" />
                <show_notification title="'[MD] Context Menu API Demo'" text="'Sub-B action triggered: %1'.[event.param.$id]" />
            </actions>
        </cue>

    </cues>
</mdscript>