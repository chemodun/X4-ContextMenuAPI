<?xml version="1.0" encoding="utf-8"?>
<mdscript name="Context_Menu_API"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:noNamespaceSchemaLocation="../../libraries/md.xsd">

  <!--
    MD-level Context Menu API.

    CONSUMER FLOW
    =============
    1. Listen to Get_Actions. event.param fields:
         $menuName  - "MapMenu"
         $mode      - contextMenuMode string, e.g. "info_context"
         $entity    - MD component (pilot/manager) or null
         $person    - NPCSeed string (crew NPC) or null
         $component - MD component (controllable: ship/station) or null
         $instance  - "left" | "right" or null

    3. Signal Add_Action (one or more times) inside Get_Actions handler.
       Fields:
         $type      - "separator" | "menuItem" | "subMenu" | "header"
                      default: "menuItem"
         $id        - mandatory for all except "separator"; used as:
                        menuItem: unique action id for callback dispatch
                        subMenu:  target custom mode id
                        header:   stable identity (no functional effect)
         $text      - display string
         $icon      - optional icon name; prepended to the text via \027[name] escape
         $text2     - optional right-column text;
                      for "subMenu" the API auto-supplies ">" if omitted
         $textColor      - optional Color key for the text (e.g. 'text_normal');
                           defaults to 'text_normal'
         $text2Color     - optional Color key for text2 (e.g. 'text_skills');
                           defaults to 'text_normal'
         $mouseOver     - optional mouseover tooltip text
         $mouseOverIcon - optional icon name to prefix before the mouseover text
         $callback  - cue to call on menuItem click;
                      event.param = Get_Actions param + $id + $echo
         $echo      - any value; passed back in callback event.param.$echo
         $active    - bool, defaults to true;
                      if false the entry is greyed out and unclickable;
                      auto-set to false when $callback is omitted
         $keepOpen  - (optional) if true the context menu stays open after click;
                      default: menu is closed on click
    -->
  <cues>

    <!-- ================================================================== -->
    <!--  Global state                                                      -->
    <!-- ================================================================== -->

    <!--
      $DebugChance  - 0 or 100
      $callbacks    - table keyed by '$actionId' → { $cue, $menuParams }
    -->
    <cue name="Globals">
      <actions>
        <include_actions ref="Reset_Globals" />
      </actions>
      <cues>
        <cue name="Reset_On_Lua_Reload" instantiate="true">
          <conditions>
            <event_ui_triggered screen="'Context_Menu_API'" control="'reloaded'" />
          </conditions>
          <actions>
            <include_actions ref="Reset_Globals" />
          </actions>
        </cue>
      </cues>
    </cue>

    <library name="Reset_Globals">
      <actions>
        <include_actions ref="DefaultConfig" />
        <set_value name="Globals.$DebugChance" exact="if $config.$debugMode != 'none' then 100 else 0" />
        <!-- Notify consumers so they can re-register modes / static actions -->
        <signal_cue_instantly cue="Reloaded" />
        <!-- Sync debug level to Lua -->
        <raise_lua_event name="'Context_Menu_API.ConfigChanged'" param="table[$debugMode = $config.$debugMode]" />
        <remove_value name="$config" />
        <set_value name="Globals.$callbacks" exact="table[]" />
        <set_value name="Globals.$lastParams" exact="table[]" />
      </actions>
    </library>

    <!-- Reads (or initialises) mod config from player.entity.$contextMenuAPIConfig.
             Leaves a local $config reference; caller must <remove_value name="$config" />. -->
    <library name="DefaultConfig" purpose="include_actions" version="1">
      <actions>
        <do_if value="@player.entity.$contextMenuAPIConfig == null">
          <set_value name="player.entity.$contextMenuAPIConfig" exact="table[
            $debugMode = 'none',
          ]" />
        </do_if>
        <set_value name="$config" exact="player.entity.$contextMenuAPIConfig" />
        <!-- forward-compat: fill keys added in later versions -->
        <do_if value="@$config.$debugMode == null">
          <set_value name="$config.$debugMode" exact="'none'" />
        </do_if>
      </actions>
    </library>


    <!-- ================================================================== -->
    <!--  Public: Reloaded                                                  -->
    <!-- ================================================================== -->

    <!--
      Signals when the Lua side (re)initialises.
      Consumers can listen here for any one-time setup work.
    -->
    <cue name="Reloaded" instantiate="true">
      <conditions>
        <event_cue_signalled />
      </conditions>
      <actions>
        <debug_text text="'[CMA] Reloaded'" chance="Globals.$DebugChance" />
      </actions>
    </cue>


    <!-- ================================================================== -->
    <!--  Options menu                                                      -->
    <!-- ================================================================== -->

    <cue name="Register_Menu" instantiate="true" version="1">
      <conditions>
        <event_cue_signalled cue="md.Simple_Menu_API.Reloaded" />
      </conditions>
      <actions>
        <signal_cue_instantly cue="md.Simple_Menu_API.Register_Options_Menu"
          param="table[
            $id      = 'context_menu_api_options',
            $columns = 12,
            $title   = {1972092426, 1},
            $onOpen  = Context_Menu_API_Options_Menu,
          ]" />
      </actions>
    </cue>

    <cue name="Context_Menu_API_Options_Menu" instantiate="true" version="1">
      <conditions>
        <event_cue_signalled />
      </conditions>
      <actions>
        <include_actions ref="DefaultConfig" />

        <!-- Section: Debug -->
        <run_actions ref="md.Options_Helper.Add_Title_Row">
          <param name="title" value="{1972092426, 90000}" />
          <param name="columns" value="12" />
        </run_actions>
        <set_value name="$debugOptions" exact="[
          table[$text = {1001, 34},           $value = 'none'],
          table[$text = {1972092426, 90012},  $value = 'debug'],
          table[$text = {1972092426, 90013},  $value = 'trace'],
        ]" />
        <set_value name="$currentIndex" exact="1" />
        <do_if value="$config.$debugMode == 'debug'">
          <set_value name="$currentIndex" exact="2" />
        </do_if>
        <do_elseif value="$config.$debugMode == 'trace'">
          <set_value name="$currentIndex" exact="3" />
        </do_elseif>
        <run_actions ref="md.Options_Helper.Add_Dropdown">
          <param name="id" value="'debugMode'" />
          <param name="options" value="$debugOptions" />
          <param name="currentIndex" value="$currentIndex" />
          <param name="col" value="1" />
          <param name="textColSpan" value="7" />
          <param name="text" value="{1972092426, 90010}" />
          <param name="dropdownColSpan" value="5" />
          <param name="handle" value="Handle_Dropdown_Changed" />
        </run_actions>
        <remove_value name="$debugOptions" />
        <remove_value name="$currentIndex" />
        <remove_value name="$config" />
      </actions>
    </cue>

    <cue name="Handle_Dropdown_Changed" instantiate="true" version="1">
      <conditions>
        <event_cue_signalled />
      </conditions>
      <actions>
        <include_actions ref="DefaultConfig" />
        <set_value name="$resultTable" exact="$config" />
        <include_actions ref="md.Options_Helper.Process_Dropdown_Changed" />
        <remove_value name="$resultTable" />
        <set_value name="Globals.$DebugChance" exact="if $config.$debugMode != 'none' then 100 else 0" />
        <raise_lua_event name="'Context_Menu_API.ConfigChanged'" param="table[$debugMode = $config.$debugMode]" />
        <remove_value name="$config" />
      </actions>
    </cue>


    <!-- ================================================================== -->
    <!--  Public: Get_Actions                                               -->
    <!-- ================================================================== -->

    <!--
      Fired every time a context frame is about to open.
      Consumers respond by signalling Add_Action (one or more times)
      within the same MD tick - all entries are collected synchronously.

      event.param fields are described in the file header.
    -->
    <cue name="Get_Actions" instantiate="true">
      <conditions>
        <event_cue_signalled />
      </conditions>
      <actions>
        <debug_text text="'[CMA] Get_Actions mode=%1 menu=%2'.[event.param.$mode, event.param.$menuName]"
          chance="Globals.$DebugChance" />
      </actions>
    </cue>


    <!-- ================================================================== -->
    <!--  Public: Add_Action                                                -->
    <!-- ================================================================== -->

    <cue name="Add_Action" instantiate="true" namespace="this">
      <conditions>
        <event_cue_signalled />
      </conditions>
      <actions>
        <set_value name="$entry" exact="event.param.clone" />
        <debug_text text="'[CMA] Add_Action called with entry: %s'.[$entry]" chance="Globals.$DebugChance" />

        <!-- Default type -->
        <do_if value="@$entry.$type == null">
          <set_value name="$entry.$type" exact="'menuItem'" />
        </do_if>

        <!-- For menuItem: auto-set active=false when no callback is provided
             (unless the caller explicitly passed $active). -->
        <do_if value="$entry.$type == 'menuItem' and @$entry.$callback == null and @$entry.$active == null">
          <set_value name="$entry.$active" exact="false" />
        </do_if>

        <!-- Auto-generate id from text only when a callback is present and no explicit $id given. -->
        <do_if value="@$entry.$id == null and @$entry.$callback != null">
          <do_if value="@$entry.$text != null">
            <set_value name="$entry.$id" exact="$entry.$text" />
          </do_if>
          <do_else>
            <set_value name="$entry.$id" exact="'cma_action_' + player.age" />
          </do_else>
        </do_if>

        <!-- Store the callback cue + echo (both stripped from entry before sending to Lua) -->
        <do_if value="@$entry.$callback != null">
          <set_value name="Globals.$callbacks.{'$' + $entry.$id}"
            exact="table[$cue = $entry.$callback, $echo = @$entry.$echo]" />
          <remove_value name="$entry.$callback" />
        </do_if>
        <do_if value="@$entry.$echo != null">
          <remove_value name="$entry.$echo" />
        </do_if>

        <!-- Ensure text is always a string -->
        <do_if value="@$entry.$text == null">
          <set_value name="$entry.$text" exact="''" />
        </do_if>

        <!-- Skip menuItem and subMenu entries that have no id: they cannot dispatch and must not be injected -->
        <do_if value="($entry.$type == 'menuItem' or $entry.$type == 'subMenu') and @$entry.$id == null">
          <debug_text text="'[CMA] Add_Action skipped: type=%1 requires an id (text=%2)'.[$entry.$type, $entry.$text]" chance="100" />
          <return />
        </do_if>

        <!-- Append to the blackboard list Lua reads after the 2-frame delay -->
        <do_if value="@player.entity.$cma_temp_entries == null">
          <set_value name="player.entity.$cma_temp_entries" exact="[]" />
        </do_if>
        <append_to_list name="player.entity.$cma_temp_entries" exact="$entry" />

        <debug_text text="'[CMA] Add_Action type=%1 id=%2 active=%3 text=%4'.
                         [$entry.$type, @$entry.$id, @$entry.$active, $entry.$text]"
          chance="Globals.$DebugChance" />
      </actions>
    </cue>


    <!-- ================================================================== -->
    <!--  Internal: capture Lua onOpen signal                               -->
    <!-- ================================================================== -->

    <cue name="Capture_onOpen" instantiate="true" namespace="this">
      <conditions>
        <event_ui_triggered screen="'Context_Menu_API'" control="'onOpen'" />
      </conditions>
      <actions>
        <debug_text text="'[CMA] onOpen, param3 = %1, is table = %2'.
          [event.param3, typeof event.param3 == datatype.table]"
          chance="Globals.$DebugChance" />
        <set_value name="$raw" exact="event.param3" />
        <do_if value="typeof $raw == datatype.table">

          <!-- Start with a copy so we don't pollute the event param -->
          <set_value name="$params" exact="$raw.clone" />

          <!-- Convert entity/component string IDs to MD components -->
          <do_for_each name="$field" in="['$entity', '$component']">
            <do_if value="$params.{$field}?">
              <do_if value="$params.{$field} == 0 or $params.{$field} == '0'">
                <set_value name="$params.{$field}" exact="null" />
              </do_if>
              <do_else>
                <set_value name="$params.{$field}"
                  exact="component.{$params.{$field}}" />
              </do_else>
            </do_if>
          </do_for_each>
          <!-- $person is NPCSeed (uint64 string) - kept as-is; not a component -->

          <!-- Clear previous temp entries and callbacks; fresh for each open -->
          <set_value name="player.entity.$cma_temp_entries" exact="null" />
          <set_value name="Globals.$callbacks" exact="table[]" />

          <!-- Store for action callbacks -->
          <set_value name="Globals.$lastParams" exact="$params" />

          <debug_text text="'[CMA] onOpen menu=%1 mode=%2'.[$params.$menuName, $params.$mode]"
            chance="Globals.$DebugChance" />

          <!-- Signal consumers - they call Add_Action synchronously here -->
          <signal_cue_instantly cue="Get_Actions" param="$params" />

        </do_if>
      </actions>
    </cue>


    <!-- ================================================================== -->
    <!--  Internal: dispatch action callbacks                                 -->
    <!-- ================================================================== -->

    <cue name="On_Action" instantiate="true" namespace="this">
      <conditions>
        <event_ui_triggered screen="'Context_Menu_API'" control="'action'" />
      </conditions>
      <actions>
        <set_value name="$id" exact="event.param3" />
        <set_value name="$key" exact="'$' + $id" />
        <do_if value="Globals.$callbacks.{$key}?">
          <!-- Build callback param: the original Get_Actions params + $id + $echo -->
          <set_value name="$cbParam" exact="Globals.$lastParams.clone" />
          <set_value name="$cbParam.$id" exact="$id" />
          <do_if value="@Globals.$callbacks.{$key}.$echo != null">
            <set_value name="$cbParam.$echo" exact="Globals.$callbacks.{$key}.$echo" />
          </do_if>
          <signal_cue_instantly cue="Globals.$callbacks.{$key}.$cue"
            param="$cbParam" />
          <debug_text text="'[CMA] On_Action dispatched id=%1'.[$id]" chance="Globals.$DebugChance" />
        </do_if>
        <do_else>
          <debug_text text="'[CMA] On_Action: no callback for id=%1'.[$id]" chance="Globals.$DebugChance" />
        </do_else>
      </actions>
    </cue>

  </cues>
</mdscript>