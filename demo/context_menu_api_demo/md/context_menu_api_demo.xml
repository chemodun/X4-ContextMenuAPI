<?xml version="1.0" encoding="utf-8"?>
<mdscript name="Context_Menu_API_Demo"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../libraries/md.xsd">

    <!--
    Context Menu API Demo — MD-level consumer demo.

    Mirrors the Lua demo mod's menu structure but with "[MD]" prefix in all labels,
    registered via the Context Menu API (md.Context_Menu_API.*).

    MENU TREE:
      [vanilla info_context]  (append, only when entity or person present)
        ─── (separator)
        [MD] Test: Multi-Level Menu >   ← submenu → cmt_md_main

      [cmt_md_main]           (custom mode, blank frame)
        Name (Role)            (header — dynamic: resolved from $data.$entity / $data.$person)
        < Back                 (auto-generated by API)
        [MD] Item A  >         → cmt_md_sub_a
        [MD] Item B  >         → cmt_md_sub_b

      [cmt_md_sub_a]
        [MD] Sub-Menu A  (header, from MD)
        < Back                 (auto-generated by API)
        [MD] A - Action 1   → On_CMA_A_Action_1
        [MD] A - Action 2   → On_CMA_A_Action_2

      [cmt_md_sub_b]
        [MD] Sub-Menu B  (header, from MD)
        < Back                 (auto-generated by API)
        [MD] B - Action 1   → On_CMA_B_Action_1
        [MD] B - Action 2   → On_CMA_B_Action_2

    Note: subMenu entries do not include ">" in $text — the API appends it automatically.
    -->

    <cues>

        <!-- ================================================================== -->
        <!--  Add entries each time a context frame is about to open              -->
        <!-- ================================================================== -->

        <cue name="On_CMA_Get_Actions" instantiate="true">
            <conditions>
                <event_cue_signalled cue="md.Context_Menu_API.Get_Actions" />
            </conditions>
            <actions>
                <debug_text text="'ContextMenuAPI Demo: Get_Actions, mode = %1, all: %s'.[event.param.$mode, event.param]" />
                <!-- info_context: append entry when an entity or crew member is shown -->
                <do_if value="event.param.$mode == 'info_context' or event.param.$mode == 'personnel'">
                    <debug_text text="'ContextMenuAPI Demo: info_context detected, entity= %s, person= %s'.[@event.param.$data.$entity, @event.param.$data.$person]" />
                    <!-- <do_if value="event.param.$data.$entity? or event.param.$data.$person?"> -->
                    <debug_text text="'ContextMenuAPI Demo: Adding entries to info_context'" />
                    <signal_cue_instantly cue="md.Context_Menu_API.Add_Action"
                        param="table[$type = 'separator']" />
                    <signal_cue_instantly cue="md.Context_Menu_API.Add_Action"
                        param="table[
                                $type = 'subMenu',
                                $text = '[MD] Test: Multi-Level Menu',
                                $id   = 'cmt_md_main',
                            ]" />
                    <signal_cue_instantly cue="md.Context_Menu_API.Add_Action"
                        param="table[$type = 'separator']" />
                    <signal_cue_instantly cue="md.Context_Menu_API.Add_Action"
                        param="table[
                            $type     = 'menuItem',
                            $text     = '[MD] Action 1',
                            $id       = 'cmt_md_b_action_1',
                            $callback = On_CMA_B_Action_1,
                            $textColor = 'text_positive',
                            $icon      = 'order_follow',
                            $keepOpen = true,
                            $echo     = table[
                              $test = 'test',
                            ],
                        ]" />
                    <signal_cue_instantly cue="md.Context_Menu_API.Add_Action"
                        param="table[
                            $type     = 'menuItem',
                            $text     = '[MD] Action 2',
                            $id       = 'cmt_md_b_action_2',
                            $callback = On_CMA_B_Action_2,
                            $textColor = 'text_negative',
                        ]" />
                    <!-- </do_if> -->
                </do_if>

                <!-- cmt_md_main: top-level custom menu -->
                <do_elseif value="event.param.$mode == 'cmt_md_main'">
                    <!-- Build dynamic header: "Name (Role)" from the selected NPC.      -->
                    <!-- event.param.$entity / $component are MD component references.   -->
                    <!-- event.param.$person is an npctemplateentry (resolved by the API) -->
                    <set_value name="$npcLabel" exact="''" />
                    <do_if value="@event.param.$entity != null">
                        <set_value name="$npcLabel"
                            exact="@event.param.$entity.knownname" />
                        <do_if value="@event.param.$component.isclass.ship_s">
                            <set_value name="$npcLabel" exact="$npcLabel + ' (Pilot)'" />
                        </do_if>
                        <do_elseif value="@event.param.$component.isclass.ship">
                            <set_value name="$npcLabel" exact="$npcLabel + ' (Captain)'" />
                        </do_elseif>
                        <do_else>
                            <set_value name="$npcLabel" exact="$npcLabel + ' (Manager)'" />
                        </do_else>
                    </do_if>
                    <do_elseif value="@event.param.$person != null">
                        <set_value name="$npcLabel"
                            exact="@event.param.$component.people.{event.param.$person}.name
                                 + ' ('
                                 + @event.param.$component.people.{event.param.$person}.role.name
                                 + ')'" />
                    </do_elseif>
                    <do_if value="$npcLabel == ''">
                        <set_value name="$npcLabel" exact="'[MD] Multi-Level Menu'" />
                    </do_if>
                    <signal_cue_instantly cue="md.Context_Menu_API.Add_Action"
                        param="table[$type = 'header', $text = $npcLabel]" />
                    <signal_cue_instantly cue="md.Context_Menu_API.Add_Action"
                        param="table[
                            $type = 'subMenu',
                            $text = '[MD] Item A',
                            $id   = 'cmt_md_sub_a',
                        ]" />
                    <signal_cue_instantly cue="md.Context_Menu_API.Add_Action"
                        param="table[
                            $type = 'subMenu',
                            $text = '[MD] Item B',
                            $id   = 'cmt_md_sub_b',
                        ]" />
                </do_elseif>

                <!-- cmt_md_sub_a: sub-menu A -->
                <do_elseif value="event.param.$mode == 'cmt_md_sub_a'">
                    <signal_cue_instantly cue="md.Context_Menu_API.Add_Action"
                        param="table[$type = 'header', $text = '[MD] Sub-Menu A']" />
                    <signal_cue_instantly cue="md.Context_Menu_API.Add_Action"
                        param="table[
                            $type     = 'menuItem',
                            $text     = '[MD] A - Action 1',
                            $id       = 'cmt_md_a_action_1',
                            $callback = On_CMA_A_Action_1,
                        ]" />
                    <signal_cue_instantly cue="md.Context_Menu_API.Add_Action"
                        param="table[
                            $type     = 'menuItem',
                            $text     = '[MD] A - Action 2',
                            $id       = 'cmt_md_a_action_2',
                            $callback = On_CMA_A_Action_2,
                        ]" />
                </do_elseif>

                <!-- cmt_md_sub_b: sub-menu B -->
                <do_elseif value="event.param.$mode == 'cmt_md_sub_b'">
                    <signal_cue_instantly cue="md.Context_Menu_API.Add_Action"
                        param="table[$type = 'header', $text = '[MD] Sub-Menu B']" />
                    <signal_cue_instantly cue="md.Context_Menu_API.Add_Action"
                        param="table[
                            $type     = 'menuItem',
                            $text     = '[MD] B - Action 1',
                            $id       = 'cmt_md_b_action_1',
                            $callback = On_CMA_B_Action_1,
                        ]" />
                    <signal_cue_instantly cue="md.Context_Menu_API.Add_Action"
                        param="table[
                            $type     = 'menuItem',
                            $text     = '[MD] B - Action 2',
                            $id       = 'cmt_md_b_action_2',
                            $callback = On_CMA_B_Action_2,
                        ]" />
                </do_elseif>

            </actions>
        </cue>


        <!-- ================================================================== -->
        <!--  Button callbacks                                                    -->
        <!-- ================================================================== -->

        <cue name="On_CMA_A_Action_1" instantiate="true">
            <conditions>
                <event_cue_signalled />
            </conditions>
            <actions>
                <debug_text text="'ContextMenuAPI Demo: A - Action 1 triggered with param: %s'.[@event.param]" chance="100" filter="general" />
            </actions>
        </cue>

        <cue name="On_CMA_A_Action_2" instantiate="true">
            <conditions>
                <event_cue_signalled />
            </conditions>
            <actions>
                <debug_text text="'ContextMenuAPI Demo: A - Action 2 triggered with param: %s'.[@event.param]" chance="100" filter="general" />
            </actions>
        </cue>

        <cue name="On_CMA_B_Action_1" instantiate="true">
            <conditions>
                <event_cue_signalled />
            </conditions>
            <actions>
                <debug_text text="'ContextMenuAPI Demo: B - Action 1 triggered with param: %s'.[@event.param]" chance="100" filter="general" />
            </actions>
        </cue>

        <cue name="On_CMA_B_Action_2" instantiate="true">
            <conditions>
                <event_cue_signalled />
            </conditions>
            <actions>
                <debug_text text="'ContextMenuAPI Demo: B - Action 2 triggered with param: %s'.[@event.param]" chance="100" filter="general" />
            </actions>
        </cue>

    </cues>
</mdscript>